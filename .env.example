# App
APP_ENV=development
SECRET_KEY=your-secret-key-min-32-chars-change-in-production

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=glimmora_reach

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# OAuth — Google (create OAuth client at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback
# SPA URL to redirect after Google login; tokens in hash fragment
FRONTEND_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback

# Super Admin seed (run: python seed.py)
SUPER_ADMIN_EMAIL=admin@glimmora.io
SUPER_ADMIN_PASSWORD=change-me-secure-password

# Invite link base URL (frontend)
INVITE_BASE_URL=http://localhost:3000

# Optional: SMTP for invite emails
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# FROM_EMAIL=noreply@glimmora.io

# Meta (Facebook) Ads API (create app at https://developers.facebook.com/apps/)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/v1/meta-ads/oauth/callback
META_GRAPH_VERSION=v19.0

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
